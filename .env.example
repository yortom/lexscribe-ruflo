# =====================================================================
# Lexscribe — environment variables (template)
# Copy to .env and fill in real values. Never commit .env to git.
# =====================================================================

# === Database ===
MONGO_URI=mongodb://localhost:27017/lexscribe

# === Object Storage (MinIO / S3) ===
S3_ENDPOINT=http://localhost:9000
S3_REGION=us-east-1
S3_BUCKET=lexscribe
S3_ACCESS_KEY=minioadmin
S3_SECRET_KEY=minioadmin
S3_FORCE_PATH_STYLE=true

# === Auth (JWT) ===
JWT_ACCESS_SECRET=change-me-access-secret-min-32-chars
JWT_REFRESH_SECRET=change-me-refresh-secret-min-32-chars
JWT_ACCESS_TTL=15m
JWT_REFRESH_TTL=7d

# === Application-level encryption (PII fields) ===
APP_ENCRYPTION_KEY=change-me-32-bytes-base64

# === Seed (initial admin user) ===
SEED_USER_EMAIL=admin@lexscribe.local
SEED_USER_PASSWORD=change-me-strong-password
SEED_USER_NAME=Admin

# === Backend ===
BACKEND_PORT=3001
NODE_ENV=development
LOG_LEVEL=debug

# === Frontend ===
NEXT_PUBLIC_API_BASE_URL=http://localhost:3001/api/v1

# === Observability ===
SENTRY_DSN=
