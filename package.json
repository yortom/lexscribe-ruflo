{
  "name": "lexscribe",
  "version": "0.0.1",
  "private": true,
  "description": "Lexscribe — automatización de contratos legales",
  "engines": {
    "node": ">=22",
    "pnpm": ">=9"
  },
  "packageManager": "pnpm@9.12.0",
  "scripts": {
    "dev": "pnpm -r --parallel dev",
    "build": "pnpm -r build",
    "lint": "pnpm -r lint",
    "test": "pnpm -r test",
    "typecheck": "pnpm -r typecheck",
    "seed": "pnpm --filter @lexscribe/backend seed",
    "format": "prettier --write \"**/*.{ts,tsx,js,jsx,json,md}\"",
    "format:check": "prettier --check \"**/*.{ts,tsx,js,jsx,json,md}\""
  },
  "devDependencies": {
    "typescript": "^5.5.0",
    "prettier": "^3.3.3",
    "eslint": "^9.10.0"
  }
}
