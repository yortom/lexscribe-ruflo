# === Backend ===
NODE_ENV=development
PORT=3001
MONGO_URI=mongodb://mongodb:27017/lexscribe
JWT_ACCESS_SECRET=change-me-min-32-chars
APP_ENCRYPTION_KEY=change-me-min-32-chars

# === MinIO ===
MINIO_ENDPOINT=minio
MINIO_PORT=9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin
MINIO_BUCKET=lexscribe

# === Nginx TLS ===
# Relative to infra/docker-compose.yml when using: docker compose -f infra/docker-compose.yml
NGINX_CERT_DIR=./nginx/certs

# === Seed ===
SEED_USER_EMAIL=admin@lexscribe.local
SEED_USER_PASSWORD=change-me-min-12-chars

# === Backup (NAS host, no contenedor) ===
# BACKUP_DIR=/var/backups/lexscribe
# RCLONE_CONFIG=/etc/rclone/rclone.conf
# REMOTE_DRIVE=gdrive:lexscribe-backup
# REMOTE_MINIO=minio:lexscribe

# === Frontend ===
NEXT_PUBLIC_API_URL=http://localhost:3001/api/v1
